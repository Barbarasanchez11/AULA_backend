# =========================================================
# AULA+ Backend - Variables de Entorno
# Copia este archivo a .env y rellena los valores reales
# =========================================================

# --- Modo de aplicación ---
DEBUG=True  # Cambiar a False en producción

# =========================================================
# BASE DE DATOS (PostgreSQL)
# =========================================================
POSTGRES_USER=aulaplus
POSTGRES_PASSWORD=tu_password_aqui
POSTGRES_DB=aulaplus_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# =========================================================
# CORS - Orígenes del Frontend
# Aquí van las URLs exactas de tu frontend (sin barra final)
# En local: separadas por comas
# En producción: la URL de Vercel, Netlify, etc.
# =========================================================
ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173

# Ejemplo producción (descomentar):
# ALLOW_ORIGINS=https://mi-front.vercel.app

# =========================================================
# INTELIGENCIA ARTIFICIAL
# =========================================================
# Hugging Face API Key (para LLM y embeddings externos)
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_MODEL_ID=BSC-LT/salamandra-7b-instruct

# Groq API Key (alternativa al LLM de HF)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx